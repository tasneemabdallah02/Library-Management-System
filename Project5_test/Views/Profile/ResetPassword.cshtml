
@model PasswordResetViewModel
@{
    Layout = "~/Views/Shared/_Layoutupdated.cshtml";
}
<style>
    :root {
        --local-tan-bg: #040404; 
        --local-button-bg: #f3ae09; 
        --local-text-gold: #CCAF74; 
        --glass-bg: rgba(255, 255, 255, 0.03);
    }

    .page-content {
        background-color: var(--local-tan-bg);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 160px);
        padding: 40px 20px;
    }

    .edit-card {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(204, 175, 116, 0.15);
        border-radius: 20px;
        padding: 45px;
        width: 100%;
        max-width: 500px; /* أصغر قليلاً من صفحة البيانات لتناسب فورم الباسوورد */
        box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6);
        color: #fff;
        animation: fadeIn 0.8s ease-in-out;
    }

    .edit-card h2 {
        text-align: center;
        margin-bottom: 35px;
        color: var(--local-text-gold);
        font-family: 'Playfair Display', serif;
        font-weight: 500;
        font-style: italic; /* إضافة اللمسة الجمالية من ثيم الهوم */
    }

    /* Form Controls */
    .form-group {
        margin-bottom: 25px;
    }

    .edit-card label {
        color: var(--local-text-gold);
        font-size: 0.95rem;
        margin-bottom: 8px;
        display: block;
        font-weight: 300;
    }

    .edit-card .form-control {
        background: rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(204, 175, 116, 0.3);
        border-radius: 12px;
        color: #fff;
        padding: 14px 18px;
        transition: all 0.3s ease;
        width: 100%;
    }

    .edit-card .form-control:focus {
        background: rgba(0, 0, 0, 0.5);
        border-color: var(--local-button-bg);
        box-shadow: 0 0 15px rgba(243, 174, 9, 0.2);
        color: #fff;
        outline: none;
    }

    .edit-card .form-control::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    /* الأزرار المطابقة لستايل صفحة التعديل */
    .form__btns {
        display: flex;
        gap: 15px;
        margin-top: 35px;
    }

    .btn-save {
        flex: 2;
        background-color: var(--local-button-bg);
        color: #000 !important;
        border: none;
        font-weight: 600;
        padding: 12px;
        border-radius: 30px;
        transition: all 0.3s;
        text-transform: uppercase;
        font-size: 0.9rem;
        letter-spacing: 1px;
        cursor: pointer;
    }

    .btn-save:hover {
        opacity: 0.9;
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(246, 167, 6, 0.3);
    }

    .btn-cancel {
        flex: 1;
        background: transparent;
        border: 1px solid rgba(204, 175, 116, 0.5);
        color: var(--local-text-gold);
        padding: 12px;
        border-radius: 30px;
        transition: all 0.3s;
        text-align: center;
        text-decoration: none;
        font-size: 0.9rem;
    }

    .btn-cancel:hover {
        background: rgba(204, 175, 116, 0.1);
        color: var(--local-text-gold);
    }

    /* تنبيهات النجاح والخطأ بنفس ألوان الثيم */
    .alert {
        padding: 12px;
        border-radius: 10px;
        margin-bottom: 25px;
        font-size: 0.85rem;
        text-align: center;
        border: 1px solid transparent;
    }

    .alert-danger {
        background: rgba(231, 76, 60, 0.1);
        color: #ff7675;
        border-color: rgba(231, 76, 60, 0.2);
    }

    .alert-success {
        background: rgba(46, 204, 113, 0.1);
        color: #2ecc71;
        border-color: rgba(46, 204, 113, 0.2);
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@media (max-width: 576px) {
        .edit-card { padding: 30px 20px; }
        .form__btns { flex-direction: column; }
    }
</style>

<div class="page-content">
    <div class="edit-card">
        <h2>Reset Password</h2>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger">@Model.ErrorMessage</div>
        }
        @if (!string.IsNullOrEmpty(Model.SuccessMessage))
        {
            <div class="alert alert-success">@Model.SuccessMessage</div>
        }

        <form asp-action="ResetPassword" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="OldPassword">Old Password</label>
                <input asp-for="OldPassword" name="OldPassword"
                       type="password" 
                       class="form-control" 
                       placeholder="Enter old password" 
                       value="@Model.OldPassword" 
                       required />
            </div>

            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <input asp-for="NewPassword" name="NewPassword" 
                       type="password" 
                       class="form-control" 
                       placeholder="Enter new password" 
                       value="@Model.NewPassword" 
                       required />
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm New Password</label>
                <input asp-for="ConfirmPassword" name="ConfirmPassword" 
                       type="password" 
                       class="form-control" 
                       placeholder="Repeat new password" 
                       value="@Model.ConfirmPassword" 
                       required />
            </div>

            <div class="form__btns">
                <button type="submit" class="btn btn-save">Update Password</button>
                <a asp-action="Index" class="btn btn-cancel">Cancel</a>
            </div>
        </form>
    </div>
</div>