@model List<Project5_test.Models.RoomReservation>
@{
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}

<style>
    /* الحاوية الرئيسية */
    .rooms-page {
        padding: 2rem;
        min-height: 100vh;
        background-color: var(--bg-primary);
        transition: background-color var(--transition-speed);
    }

    /* رأس الصفحة */
    .rooms-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
    }

        .rooms-header h2 {
            color: var(--text-primary);
            font-weight: 700;
            margin: 0;
            letter-spacing: -0.5px;
        }

    /* زر الإضافة العصري */
    .btn-add-room {
        background: var(--gradient-primary);
        color: white;
        padding: 0.75rem 1.5rem;
        border-radius: 12px;
        font-weight: 600;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 8px;
        box-shadow: var(--neon-glow);
        transition: all var(--transition-speed);
        border: none;
    }

        .btn-add-room:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(109, 90, 205, 0.4);
            color: white;
        }

    /* بطاقة الجدول */
    .rooms-card {
        background-color: var(--bg-secondary);
        border-radius: 16px;
        border: 1px solid var(--bg-tertiary);
        box-shadow: var(--card-shadow);
        overflow: hidden;
        transition: all var(--transition-speed);
    }

    /* تنسيق الجدول */
    .table-container {
        width: 100%;
        overflow-x: auto;
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }

        .modern-table thead {
            background-color: var(--bg-tertiary);
        }

        .modern-table th {
            padding: 1.25rem;
            color: var(--text-secondary);
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 600;
            border-bottom: 1px solid var(--bg-tertiary);
        }

        .modern-table td {
            padding: 1.25rem;
            color: var(--text-primary);
            border-bottom: 1px solid var(--bg-tertiary);
            vertical-align: middle;
        }

        .modern-table tbody tr {
            transition: background-color var(--transition-speed);
        }

            .modern-table tbody tr:hover {
                background-color: rgba(109, 90, 205, 0.05);
            }

    /* عناصر مخصصة */
    .room-name-wrapper {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .room-icon {
        width: 40px;
        height: 40px;
        background-color: var(--bg-tertiary);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--accent-primary);
        font-size: 1.1rem;
    }

    .capacity-badge {
        background-color: rgba(67, 97, 238, 0.1);
        color: var(--accent-secondary);
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 700;
        font-size: 0.85rem;
    }

    .action-group {
        display: flex;
        gap: 10px;
    }

    .btn-edit {
        color: var(--warning);
        background: rgba(255, 165, 2, 0.1);
        border: 1px solid var(--warning);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        transition: all 0.2s;
    }

        .btn-edit:hover {
            background: var(--warning);
            color: white;
        }

    .btn-delete {
        color: var(--danger);
        background: rgba(255, 71, 87, 0.1);
        border: 1px solid var(--danger);
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.8rem;
        transition: all 0.2s;
    }

        .btn-delete:hover {
            background: var(--danger);
            color: white;
        }

    .empty-state {
        padding: 5rem 2rem;
        text-align: center;
        color: var(--text-secondary);
    }

    /* تحسين للهواتف */
    @@media (max-width: 768px) {
        .rooms-page {
            padding: 1rem;
        }

        .rooms-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
    }
</style>

<div class="rooms-page">
    <div class="rooms-header">
        <div>
            <h2>Manage <span style="color: var(--accent-primary)">Rooms</span></h2>
            <p style="color: var(--text-secondary); margin-top: 5px;">View and configure available library rooms</p>
        </div>
        <a asp-action="AddRoom" class="btn-add-room">
            <i class="fas fa-plus"></i> Add New Room
        </a>
    </div>

    <div class="rooms-card">
        <div class="table-container">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>Room Details</th>
                        <th>Capacity</th>
                        <th>Available Time</th>
                        <th>Date Added</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var room in Model)
                        {
                            <tr>
                                <td>
                                    <div class="room-name-wrapper">
                                        <div class="room-icon">
                                            <i class="fas fa-door-closed"></i>
                                        </div>
                                        <div>
                                            <div style="font-weight: 600;">@room.Room.RoomName</div>
                                            <small style="color: var(--text-secondary)">ID: #@room.RoomId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="capacity-badge">
                                        <i class="fas fa-users mr-1"></i>  @(room.User != null
                                                                        ? room.User.FirstName + " " + room.User.LastName
                                                                        : "No User")
                                    </span>
                                </td>
                                <td>
                                    <div style="color: var(--text-primary); font-size: 0.9rem;">
                                        <i class="far fa-clock mr-1" style="color: var(--accent-secondary)"></i>
                                        @room.StartTime - @room.EndTime
                                    </div>
                                </td>
                                <td>
                                    <div style="color: var(--text-secondary); font-size: 0.85rem;">
                                        @room.ReservationDate.?.ToShortDateString()
                                    </div>
                                </td>
                                <td>
                                    <div class="action-group">
                                        <a asp-action="EditRoom" asp-route-id="@room.RoomId" class="btn-edit">
                                            <i class="fas fa-edit"></i> Edit
                                        </a>

                                        <form asp-action="DeleteRoom" method="post" onsubmit="return confirm('Are you sure you want to delete this room?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@room.RoomId" />
                                            <button type="submit" class="btn-delete">
                                                <i class="fas fa-trash-alt"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="fas fa-folder-open fa-3x mb-3" style="color: var(--bg-tertiary)"></i>
                                    <h4>No Rooms Found</h4>
                                    <p>Start by adding a new room to the system.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
