@model IEnumerable<Project5_test.Models.RoomReservation>
@{
    ViewData["Title"] = "Reservations Management";
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}

<!-- Google Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --royal-black: #050505;
        --deep-gray: #0f0f0f;
        --gold-linear: linear-gradient(135deg, #d4af37 0%, #f3cf7a 100%);
        --gold-glow: 0 0 15px rgba(212, 175, 55, 0.15);
        --border-glass: rgba(255, 255, 255, 0.08);
        --text-main: #f0f0f0;
        --text-dim: #a0a0a0;
        --accent-gold: #d4af37;
        --success-emerald: #10b981;
        --danger-ruby: #ef4444;
    }

    .management-page {
        padding: 40px 2rem;
        background-color: var(--royal-black);
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
    }

    .table-container {
        background-color: var(--deep-gray);
        border-radius: 24px;
        padding: 2.5rem;
        border: 1px solid var(--border-glass);
        box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .header-section {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2.5rem;
        border-bottom: 1px solid var(--border-glass);
        padding-bottom: 1.5rem;
    }

        .header-section h2 {
            font-family: 'Playfair Display', serif;
            color: var(--accent-gold);
            font-size: 2.2rem;
            margin: 0;
        }

    /* Luxury Table Styles */
    .luxury-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 12px;
    }

        .luxury-table thead th {
            color: var(--accent-gold);
            text-transform: uppercase;
            font-size: 0.75rem;
            font-weight: 700;
            letter-spacing: 1.5px;
            padding: 15px 25px;
            border-bottom: none;
        }

        .luxury-table tbody tr {
            background: rgba(255, 255, 255, 0.02);
            transition: all 0.3s ease;
        }

            .luxury-table tbody tr:hover {
                background: rgba(255, 255, 255, 0.05);
                transform: scale(1.005);
            }

        .luxury-table td {
            padding: 20px 25px;
            color: var(--text-main);
            vertical-align: middle;
            border-top: 1px solid var(--border-glass);
            border-bottom: 1px solid var(--border-glass);
        }

            .luxury-table td:first-child {
                border-left: 1px solid var(--border-glass);
                border-radius: 15px 0 0 15px;
            }

            .luxury-table td:last-child {
                border-right: 1px solid var(--border-glass);
                border-radius: 0 15px 15px 0;
            }

    /* User Profile Info */
    .user-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .user-avatar {
        width: 40px;
        height: 40px;
        background: var(--gold-linear);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #000;
        font-weight: 700;
        font-size: 0.9rem;
    }

    /* Status Badge */
    .status-badge {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-pending {
        background: rgba(212, 175, 55, 0.1);
        color: var(--accent-gold);
        border: 1px solid rgba(212, 175, 55, 0.2);
    }

    .status-processed {
        background: rgba(255, 255, 255, 0.05);
        color: var(--text-dim);
        border: 1px solid var(--border-glass);
    }

    /* Action Buttons */
    .btn-action {
        width: 38px;
        height: 38px;
        border-radius: 10px;
        border: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        transition: 0.3s;
        margin-right: 5px;
        color: white;
    }

    .btn-approve {
        background: rgba(16, 185, 129, 0.1);
        color: var(--success-emerald);
        border: 1px solid rgba(16, 185, 129, 0.2);
    }

        .btn-approve:hover {
            background: var(--success-emerald);
            color: white;
            box-shadow: 0 0 15px rgba(16, 185, 129, 0.3);
        }

    .btn-reject {
        background: rgba(239, 68, 68, 0.1);
        color: var(--danger-ruby);
        border: 1px solid rgba(239, 68, 68, 0.2);
    }

        .btn-reject:hover {
            background: var(--danger-ruby);
            color: white;
            box-shadow: 0 0 15px rgba(239, 68, 68, 0.3);
        }

    .processed-label {
        font-size: 0.8rem;
        color: var(--text-dim);
        font-style: italic;
    }
</style>

<div class="management-page">
    <div class="table-container">

        <div class="header-section">
            <div>
                <h2>Room Reservations</h2>
                <p style="color: var(--text-dim); margin-top: 5px; font-size: 0.9rem;">Manage and audit guest access to luxury suites.</p>
            </div>
            <i class="fas fa-calendar-check fa-3x" style="color: var(--accent-gold); opacity: 0.5;"></i>
        </div>

        <div class="table-responsive">
            <table class="luxury-table">
                <thead>
                    <tr>
                        <th>Distinguished Guest</th>
                        <th>Chamber / Room</th>
                        <th>Current Status</th>
                        <th style="text-align: right;">Administrative Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var res in Model)
                    {
                        <tr>
                            <td>
                                <div class="user-info">
                                    <div class="user-avatar">
                                        @res.User.FirstName.Substring(0, 1)
                                    </div>
                                    <div>
                                        <div style="font-weight: 600;">@res.User.FirstName @res.User.LastName</div>
                                        <div style="font-size: 0.75rem; color: var(--text-dim);">Patron ID: #@res.UserId</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div style="font-weight: 500;">@res.Room.RoomName</div>
                                <div style="font-size: 0.75rem; color: var(--accent-gold);">Premium Suite</div>
                            </td>
                            <td>
                                <span class="status-badge @(res.StatusId == 1 ? "status-pending" : "status-processed")">
                                    <i class="fas @(res.StatusId == 1 ? "fa-hourglass-half" : "fa-check-circle")" style="margin-right: 5px;"></i>
                                    @res.Status.StatusName
                                </span>
                            </td>
                            <td style="text-align: right;">
                                @if (res.StatusId == 1)
                                {
                                    <form asp-action="ApproveReservation" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@res.ReservationId" />
                                        <button type="submit" class="btn-action btn-approve" title="Approve Request">
                                            <i class="fas fa-check"></i>
                                        </button>
                                    </form>

                                    <form asp-action="RejectReservation" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@res.ReservationId" />
                                        <button type="submit" class="btn-action btn-reject" title="Decline Request">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="processed-label">
                                        <i class="fas fa-lock" style="font-size: 0.7rem; margin-right: 5px;"></i>
                                        Archived
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>