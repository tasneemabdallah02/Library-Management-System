@model Project5_test.Models.Book
<h2>Confirm Delete Book</h2>

<p>Are you sure you want to delete the book: <strong>@Model.BookName</strong> by @Model.Author?</p>

<form asp-action="DeleteBookConfirmed" method="post">
    <input type="hidden" name="id" value="@Model.BookId" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="BooksList" class="btn btn-secondary">Cancel</a>
</form>}

@if (TempData["SuccessMessage"] != null)
{
    <script>
        alert('@TempData["SuccessMessage"]');
    </script>
}
@if (TempData["ErrorMessage"] != null)
{
    <script>
        alert('@TempData["ErrorMessage"]');
    </script>
}