@model Project5_test.Models.Book
@{
    ViewData["Title"] = "Edit Book";
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}

<!-- Google Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --royal-black: #050505;
        --deep-gray: #0f0f0f;
        --gold-linear: linear-gradient(135deg, #d4af37 0%, #f3cf7a 100%);
        --gold-glow: 0 0 20px rgba(212, 175, 55, 0.15);
        --border-glass: rgba(255, 255, 255, 0.08);
        --text-main: #f0f0f0;
        --text-dim: #a0a0a0;
        --accent-gold: #d4af37;
    }

    body {
        background-color: var(--royal-black);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }

    .edit-book-page {
        padding: 60px 20px;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: flex-start;
    }

    .form-container {
        background-color: var(--deep-gray);
        border-radius: 24px;
        padding: 3rem;
        width: 100%;
        max-width: 650px;
        border: 1px solid var(--border-glass);
        box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        animation: slideUp 0.6s ease-out;
    }

    /* Use double @@ for Razor to escape CSS keyframes */
    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-header {
        margin-bottom: 2.5rem;
        text-align: center;
    }

        .form-header i {
            background: var(--gold-linear);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .form-header h2 {
            font-family: 'Playfair Display', serif;
            color: var(--accent-gold);
            font-size: 2.2rem;
            margin: 0;
            letter-spacing: 0.5px;
        }

    .form-group {
        margin-bottom: 1.8rem;
    }

        .form-group label {
            display: block;
            color: var(--text-dim);
            margin-bottom: 0.8rem;
            font-weight: 500;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .input-wrapper {
        position: relative;
    }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent-gold);
            font-size: 1rem;
        }

    .form-control {
        width: 100%;
        padding: 1rem 1rem 1rem 3rem;
        border-radius: 12px;
        background-color: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border-glass);
        color: var(--text-main);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--accent-gold);
            background-color: rgba(255, 255, 255, 0.06);
            box-shadow: var(--gold-glow);
        }

    .image-preview-card {
        background: rgba(212, 175, 55, 0.03);
        border: 1px dashed rgba(212, 175, 55, 0.2);
        border-radius: 15px;
        padding: 25px;
        text-align: center;
        margin-bottom: 2rem;
    }

    .preview-img {
        width: 130px;
        height: 190px;
        border-radius: 10px;
        object-fit: cover;
        box-shadow: var(--gold-glow);
        border: 2px solid var(--accent-gold);
        margin-bottom: 15px;
        transition: 0.3s;
    }

    .btn-submit {
        background: var(--gold-linear);
        color: #000;
        padding: 1.1rem;
        border-radius: 12px;
        border: none;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
        transition: 0.4s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dim);
        text-decoration: none;
        margin-bottom: 2rem;
        font-size: 0.85rem;
        transition: 0.3s;
        font-weight: 500;
    }

        .btn-back:hover {
            color: var(--accent-gold);
        }

    .custom-alert {
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.9rem;
    }

    .alert-success {
        background: rgba(46, 213, 115, 0.1);
        color: #2ed573;
        border: 1px solid rgba(46, 213, 115, 0.2);
    }

    .alert-danger {
        background: rgba(255, 71, 87, 0.1);
        color: #ff4757;
        border: 1px solid rgba(255, 71, 87, 0.2);
    }

    .text-danger {
        color: #ff4757;
        font-size: 0.75rem;
        margin-top: 5px;
        display: block;
    }
</style>

<div class="edit-book-page">
    <div class="form-container">
        @if (TempData["BookSuccess"] != null)
        {
            <div class="custom-alert alert-success">
                <i class="fas fa-check-circle"></i>
                <span>@TempData["BookSuccess"]</span>
            </div>
        }

        @if (TempData["BookError"] != null)
        {
            <div class="custom-alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                <span>@TempData["BookError"]</span>
            </div>
        }

        <a asp-action="BooksManagement" class="btn-back">
            <i class="fas fa-chevron-left"></i> Return to Catalog
        </a>

        <div class="form-header">
            <i class="fas fa-book-open fa-3x"></i>
            <h2>Curate Book <span style="font-weight: 300; color: var(--text-main);">Details</span></h2>
            <p style="color: var(--text-dim); font-size: 0.85rem; margin-top: 8px;">Update literary assets and metadata</p>
        </div>

        <form asp-action="EditBook" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="BookId" />

            <div class="image-preview-card">
                <img src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/default-book.png" : Model.ImagePath)"
                     class="preview-img" alt="Book Cover" id="bookPreview"
                     onerror="this.src='https://via.placeholder.com/130x190?text=No+Cover'" />
                <br />
                <span style="font-size: 0.75rem; color: var(--accent-gold); text-transform: uppercase; font-weight: 700;">Archive Asset #@Model.BookId</span>
            </div>

            <div class="form-group">
                <label asp-for="BookName">Publication Title</label>
                <div class="input-wrapper">
                    <i class="fas fa-bookmark"></i>
                    <input asp-for="BookName" class="form-control" placeholder="Enter book title..." />
                </div>
                <span asp-validation-for="BookName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Author">Author / Creator</label>
                <div class="input-wrapper">
                    <i class="fas fa-user-nib"></i>
                    <input asp-for="Author" class="form-control" placeholder="Enter author name..." />
                </div>
                <span asp-validation-for="Author" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category">Classification Category</label>
                <div class="input-wrapper">
                    <i class="fas fa-tags"></i>
                    <select asp-for="Category" class="form-control">
                        <option value="">-- Select Category --</option>
                        <option value="History">History</option>
                        <option value="Sciences">Sciences</option>
                        <option value="Math">Math</option>
                        <option value="Engineering">Engineering</option>
                        <option value="Literature">Literature</option>
                    </select>
                </div>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="ImagePath">Cover Illustration URL</label>
                <div class="input-wrapper">
                    <i class="fas fa-image"></i>
                    <input asp-for="ImagePath" class="form-control" placeholder="Enter image URL..."
                           oninput="document.getElementById('bookPreview').src = this.value" />
                </div>
                <p style="color: var(--text-dim); font-size: 0.7rem; margin-top: 5px; font-style: italic;">
                    Updating the URL will synchronize the preview above.
                </p>
                <span asp-validation-for="ImagePath" class="text-danger"></span>
            </div>

            <button type="submit" class="btn-submit">
                <i class="fas fa-save"></i> Synchronize Changes
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}