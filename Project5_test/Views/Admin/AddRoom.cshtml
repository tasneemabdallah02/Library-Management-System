
@model Project5_test.Models.Room
@{
    Layout = "/Views/Shared/_LayoutDash.cshtml";
    ViewData["Title"] = "Add New Room";
}
<style>
     .add-room-page {
         padding: 2rem;
         background-color: var(--bg-primary);
         min-height: calc(100vh - 60px);
         display: flex;
         justify-content: center;
         align-items: flex-start;
     }

    .form-container {
        background-color: var(--bg-secondary);
        border-radius: 20px;
        padding: 2.5rem;
        width: 100%;
        max-width: 650px;
        border: 1px solid var(--bg-tertiary);
        box-shadow: var(--card-shadow);
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-header {
        margin-bottom: 2rem;
        border-bottom: 2px solid var(--bg-primary);
        padding-bottom: 1rem;
        display: flex;
        align-items: center;
        gap: 15px;
    }

        .form-header h2 {
            color: var(--text-primary);
            font-weight: 800;
            margin: 0;
            font-size: 1.5rem;
        }

    .form-group {
        margin-bottom: 1.5rem;
    }

        .form-group label {
            display: block;
            color: var(--text-secondary);
            margin-bottom: 0.6rem;
            font-weight: 600;
            font-size: 0.9rem;
        }

    .form-control {
        width: 100%;
        padding: 0.8rem 1.2rem;
        border-radius: 12px;
        background-color: var(--bg-primary);
        border: 1px solid var(--bg-tertiary);
        color: var(--text-primary);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-size: 1rem;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 4px rgba(109, 90, 205, 0.1);
            background-color: #fff;
        }

    .btn-submit {
        background: var(--gradient-primary);
        color: white;
        padding: 1rem 2rem;
        border-radius: 14px;
        border: none;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
        transition: 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 1.1rem;
        margin-top: 1rem;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: var(--neon-glow);
        }

    .room-preview-card {
        display: flex;
        align-items: center;
        gap: 20px;
        background: var(--bg-primary);
        padding: 1.2rem;
        border-radius: 15px;
        margin-bottom: 2rem;
        border: 1px solid var(--bg-tertiary);
    }

    .room-icon-box {
        width: 60px;
        height: 60px;
        background: var(--gradient-primary);
        border-radius: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.8rem;
        box-shadow: var(--card-shadow);
    }
</style>
<div class="add-room-page">
    <div class="form-container">
        <div class="form-header">
            <i class="fas fa-door-open fa-2x" style="color: var(--accent-primary)"></i>
            <h2>Create New Room</h2>
        </div>
        <div class="room-preview-card">
            <div class="room-icon-box">
                <i class="fas fa-chalkboard"></i>
            </div>
            <div>
                <strong id="preview-name" style="display: block; color: var(--text-primary); font-size: 1.1rem;">Room Name</strong>
                <span id="preview-capacity" style="font-size: 0.85rem; color: var(--text-secondary);">Capacity: 0 people</span>
            </div>
        </div>

        <form asp-action="AddRoom" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="RoomName"><i class="fas fa-signature"></i> Room Title</label>
                <input asp-for="RoomName" id="room-input" class="form-control" placeholder="e.g. Lab A1" required />
                <span asp-validation-for="RoomName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Capacity"><i class="fas fa-users"></i> Capacity (People)</label>
                <input asp-for="Capacity" id="capacity-input" class="form-control" placeholder="How many people?" required type="number" min="1" />
                <span asp-validation-for="Capacity" class="text-danger"></span>
            </div>

            <div class="row" style="display: flex; gap: 15px;">
                <div class="form-group" style="flex: 1;">
                    <label for="date"><i class="fas fa-calendar-alt"></i> Available Date</label>
                    <input type="date" id="date" name="date" class="form-control" required />
                </div>

                <div class="form-group" style="flex: 1;">
                    <label for="startTime"><i class="fas fa-clock"></i> Start Time</label>
                    <input type="time" id="startTime" name="startTime" class="form-control" required />
                </div>
            </div>

            <button type="submit" class="btn-submit">
                <i class="fas fa-plus-circle"></i> Create Room
            </button>
        </form>
    </div>
</<div>

@{
    await Html.RenderPartialAsync("_ValidationScriptsPartial");
}
    <script>

const roomIn = document.getElementById('room-input');
const capIn = document.getElementById('capacity-input');
const roomPre = document.getElementById('preview-name');
const capPre = document.getElementById('preview-capacity');
                    roomIn.addEventListener('input', (e) => {
                        roomPre.textContent = e.target.value || "Room Name";
                    });

                    capIn.addEventListener('input', (e) => {
                        capPre.textContent = e.target.value ? `Capacity: ${e.target.value} people` : "Capacity: 0 people";
                    });
            </script>
