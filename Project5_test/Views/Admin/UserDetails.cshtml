@model Project5_test.Models.User
@{
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}

<style>
    :root {
        --gold-primary: #d4af37;
        --black-deep: #050507;
        --black-surface: #0a0a0c;
        --border-gold: rgba(212, 175, 55, 0.2);
        --text-mid: #94949e;
    }

    .details-page {
        padding: 3rem;
        background-color: var(--black-deep);
        background-image: radial-gradient(circle at 10% 10%, rgba(212, 175, 55, 0.05) 0%, transparent 50%), linear-gradient(rgba(5, 5, 7, 0.98), rgba(5, 5, 7, 0.98));
        min-height: 100vh;
        font-family: 'Montserrat', sans-serif;
    }

    /* كرت البروفايل العلوي - طراز ملكي */
    .profile-header-card {
        background-color: var(--black-surface);
        border: 1px solid var(--border-gold);
        border-radius: 0; /* زوايا حادة للمظهر الرسمي */
        padding: 3rem;
        display: flex;
        align-items: center;
        gap: 3rem;
        margin-bottom: 3rem;
        position: relative;
        overflow: hidden;
        box-shadow: 0 20px 50px rgba(0,0,0,0.5);
    }

        .profile-header-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: linear-gradient(90deg, transparent, var(--gold-primary), transparent);
        }

    .profile-pic-container {
        position: relative;
        padding: 8px;
        border: 1px solid var(--border-gold);
    }

    .profile-pic {
        width: 160px;
        height: 160px;
        object-fit: cover;
        border: 1px solid var(--gold-primary);
        filter: grayscale(0.2);
    }

    .status-indicator {
        position: absolute;
        bottom: -5px;
        right: -5px;
        width: 15px;
        height: 15px;
        border-radius: 50%;
        border: 2px solid var(--black-surface);
    }

    .status-active {
        background-color: #2ecc71;
        box-shadow: 0 0 10px #2ecc71;
    }

    .status-inactive {
        background-color: #e74c3c;
        box-shadow: 0 0 10px #e74c3c;
    }

    .user-main-info h1 {
        margin: 0;
        color: #fff;
        font-family: 'Cinzel', serif;
        font-size: 2.5rem;
        letter-spacing: 2px;
        text-transform: uppercase;
    }

    .role-badge {
        display: inline-block;
        padding: 6px 15px;
        border: 1px solid var(--gold-primary);
        color: var(--gold-primary);
        font-family: 'Cinzel', serif;
        font-size: 0.7rem;
        letter-spacing: 2px;
        margin-top: 15px;
        background: rgba(212, 175, 55, 0.05);
    }

    /* شبكة المعلومات */
    .info-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .info-item {
        background-color: var(--black-surface);
        padding: 2rem;
        border-left: 2px solid var(--gold-primary);
        transition: 0.3s;
    }

        .info-item:hover {
            background-color: rgba(212, 175, 55, 0.02);
            transform: translateX(5px);
        }

    .info-label {
        color: var(--gold-primary);
        font-family: 'Cinzel', serif;
        font-size: 0.65rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-bottom: 10px;
        display: block;
    }

    .info-value {
        color: #fff;
        font-weight: 300;
        font-size: 1.1rem;
        letter-spacing: 1px;
    }

    /* قسم سجل الاستعارات */
    .borrow-section {
        background-color: var(--black-surface);
        border: 1px solid var(--border-gold);
        padding: 3rem;
    }

    .section-title {
        font-family: 'Cinzel', serif;
        color: #fff;
        letter-spacing: 3px;
        text-transform: uppercase;
        border-bottom: 1px solid var(--border-gold);
        padding-bottom: 1rem;
        margin-bottom: 2rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .borrow-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }

    .book-title {
        font-family: 'Cinzel', serif;
        font-weight: 600;
        color: var(--gold-primary);
        font-size: 1rem;
        letter-spacing: 1px;
    }

    .status-pill {
        padding: 5px 15px;
        border: 1px solid rgba(255,255,255,0.1);
        font-size: 0.65rem;
        font-family: 'Cinzel', serif;
        color: var(--text-mid);
        text-transform: uppercase;
    }

    .error-announcement {
        border: 1px solid #8b0000;
        background: rgba(139, 0, 0, 0.1);
        color: #ff5e5e;
        padding: 2rem;
        font-family: 'Cinzel', serif;
        text-align: center;
        letter-spacing: 2px;
    }

    @@media (max-width: 768px) {
        .profile-header-card {
            flex-direction: column;
            text-align: center;
            padding: 2rem;
        }
    }
</style>

<div class="details-page">
    @if (Model == null)
    {
        <div class="error-announcement">
            <i class="fas fa-exclamation-octagon fa-2x mb-3"></i><br>
            CRITICAL ERROR: SUBJECT DATA NOT FOUND IN ARCHIVES
        </div>
    }
    else
    {
        <!-- Subject Header -->
        <div class="profile-header-card">
            <div class="profile-pic-container">
                @if (!string.IsNullOrEmpty(Model.ProfilePicture))
                {
                    <img src="@Model.ProfilePicture" alt="Profile" class="profile-pic" />
                }
                else
                {
                    <img src="https://ui-avatars.com/api/?name=@(Model.FirstName ?? "U")&background=0a0a0c&color=d4af37&size=160" class="profile-pic" />
                }
                <div class="status-indicator @(Model.AccountStatus == "Active" ? "status-active" : "status-inactive")"></div>
            </div>

            <div class="user-main-info">
                <h1>@(Model.FirstName ?? "Unknown") @(Model.LastName ?? "Subject")</h1>
                <span class="role-badge">Clearance: @(Model.Role ?? "Standard Member")</span>
                <p style="color: var(--text-mid); margin-top: 15px; font-size: 0.8rem; letter-spacing: 1px;">
                    NODE STATUS:
                    <span style="color: @(Model.AccountStatus == "Active" ? "#2ecc71" : "#e74c3c")">@(Model.AccountStatus?.ToUpper() ?? "UNDEFINED")</span>
                </p>
            </div>
        </div>

        <!-- Credentials Grid -->
        <div class="info-grid">
            <div class="info-item">
                <span class="info-label">Communication Channel</span>
                <span class="info-value">@(Model.Email ?? "SECURE")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Encrypted Line</span>
                <span class="info-value">@(Model.Phone ?? "UNLISTED")</span>
            </div>
            <div class="info-item">
                <span class="info-label">Archive Identifier</span>
                <span class="info-value">#@Model.UserId</span>
            </div>
            <div class="info-item">
                <span class="info-label">Authentication Data</span>
                <span class="info-value" style="opacity: 0.3; font-size: 0.8rem;">PBKDF2_SHA256_HASH_PROTECTED</span>
            </div>
        </div>

        <!-- Archives Section -->
        <div class="borrow-section">
            <div class="section-title">
                <span><i class="fas fa-scroll mr-3"></i> Access History</span>
                <span style="font-size: 0.7rem; color: var(--gold-primary)">Logged Records: @(Model.Borrowings?.Count ?? 0)</span>
            </div>

            @if (Model.Borrowings != null && Model.Borrowings.Any())
            {
                <div class="borrow-list">
                    @foreach (var borrow in Model.Borrowings)
                    {
                        if (borrow != null)
                        {
                            <div class="borrow-item">
                                <div class="book-info">
                                    <span class="book-title">@(borrow.Book?.BookName ?? "Classified Document")</span>
                                    <div style="font-size: 0.7rem; color: var(--text-mid); margin-top: 5px; text-transform: uppercase;">
                                        Acquisition Date: @(borrow.BorrowDate.HasValue? borrow.BorrowDate.Value.ToShortDateString() : "Pending")
                                    </div>
                                </div>
                                <span class="status-pill">@(borrow.Status?.StatusName ?? "Processing")</span>
                            </div>
                        }
                    }
                </div>

                <div style="margin-top: 2rem; padding: 1rem; border: 1px dashed var(--border-gold); font-size: 0.7rem; color: var(--gold-primary); text-align: center; letter-spacing: 1px;">
                    <i class="fas fa-shield-check"></i> SYSTEM NOTE: DATA INTEGRITY VERIFIED BY THE ROYAL ARCHIVE SENSOR
                </div>
            }
            else
            {
                <div style="text-align: center; padding: 5rem 2rem; color: rgba(255,255,255,0.1);">
                    <i class="fas fa-feather-alt fa-3x mb-4"></i>
                    <p style="font-family: 'Cinzel'; letter-spacing: 2px;">No activity found for this subject in the current epoch.</p>
                </div>
            }
        </div>

        <div style="margin-top: 2rem; display: flex; justify-content: flex-start;">
            <a href="javascript:history.back()" style="color: var(--gold-primary); text-decoration: none; font-family: 'Cinzel'; font-size: 0.7rem; letter-spacing: 2px;">
                <i class="fas fa-chevron-left mr-2"></i> Return to Directory
            </a>
        </div>
    }
</div>