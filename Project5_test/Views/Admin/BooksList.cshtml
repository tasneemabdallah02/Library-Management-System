@model List<Project5_test.Models.Book>
@{
    ViewData["Title"] = "Books Catalog";
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}

<!-- Google Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --royal-black: #050505;
        --deep-gray: #0f0f0f;
        --gold-linear: linear-gradient(135deg, #d4af37 0%, #f3cf7a 100%);
        --gold-glow: 0 0 20px rgba(212, 175, 55, 0.15);
        --border-glass: rgba(255, 255, 255, 0.08);
        --text-main: #f0f0f0;
        --text-dim: #a0a0a0;
        --accent-gold: #d4af37;
        --danger-red: #ff4757;
    }

    .books-page {
        padding: 40px 2rem;
        background-color: var(--royal-black);
        min-height: 100vh;
        font-family: 'Inter', sans-serif;
    }

    /* Alerts Area */
    .alert-container {
        position: fixed;
        top: 30px;
        right: 30px;
        z-index: 9999;
    }

    .custom-alert {
        padding: 1.2rem 2rem;
        border-radius: 16px;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 15px;
        backdrop-filter: blur(10px);
        box-shadow: 0 15px 35px rgba(0,0,0,0.4);
        animation: slideIn 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        min-width: 320px;
    }

    @@keyframes slideIn {
        from {
            transform: translateX(120%);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    .alert-success {
        background: rgba(46, 213, 115, 0.9);
        color: white;
        border-left: 5px solid #1e90ff;
    }

    .alert-danger {
        background: rgba(255, 71, 87, 0.9);
        color: white;
        border-left: 5px solid #ff1f1f;
    }

    /* Header Section */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
    }

    .page-title h2 {
        font-family: 'Playfair Display', serif;
        color: var(--accent-gold);
        font-weight: 700;
        margin: 0;
        font-size: 2.2rem;
        letter-spacing: 0.5px;
    }

    /* Table Design */
    .table-container {
        background-color: var(--deep-gray);
        border-radius: 24px;
        padding: 2rem;
        border: 1px solid var(--border-glass);
        box-shadow: 0 20px 40px rgba(0,0,0,0.5);
    }

    .custom-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0 15px;
    }

        .custom-table th {
            color: var(--text-dim);
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 1.5px;
            padding: 0 1.5rem 1rem;
            border-bottom: 1px solid var(--border-glass);
        }

        .custom-table tbody tr {
            background-color: rgba(255, 255, 255, 0.02);
            transition: all 0.3s ease;
        }

            .custom-table tbody tr:hover {
                background-color: rgba(212, 175, 55, 0.05);
                transform: scale(1.005);
            }

        .custom-table td {
            padding: 1.2rem 1.5rem;
            vertical-align: middle;
            border-top: 1px solid var(--border-glass);
            border-bottom: 1px solid var(--border-glass);
        }

            .custom-table td:first-child {
                border-left: 1px solid var(--border-glass);
                border-radius: 15px 0 0 15px;
            }

            .custom-table td:last-child {
                border-right: 1px solid var(--border-glass);
                border-radius: 0 15px 15px 0;
            }

    /* Book Assets */
    .book-cover {
        width: 55px;
        height: 75px;
        border-radius: 8px;
        object-fit: cover;
        box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        border: 1px solid var(--accent-gold);
    }

    .book-title {
        font-weight: 600;
        color: var(--text-main);
        font-size: 1rem;
        margin-bottom: 4px;
        display: block;
    }

    .book-id {
        font-size: 0.7rem;
        color: var(--accent-gold);
        font-weight: 700;
        text-transform: uppercase;
    }

    .badge-category {
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
        background: rgba(212, 175, 55, 0.1);
        color: var(--accent-gold);
        border: 1px solid rgba(212, 175, 55, 0.2);
        text-transform: uppercase;
    }

    /* Action Buttons */
    .btn-add-book {
        background: var(--gold-linear);
        color: #000;
        padding: 12px 24px;
        border-radius: 12px;
        text-decoration: none;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: 10px;
        transition: 0.4s;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

        .btn-add-book:hover {
            transform: translateY(-3px);
            box-shadow: var(--gold-glow);
            color: #000;
        }

    .action-btns {
        display: flex;
        gap: 10px;
        justify-content: center;
    }

    .btn-action {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 10px;
        transition: 0.3s;
        border: 1px solid transparent;
        cursor: pointer;
        text-decoration: none;
    }

    .btn-edit {
        background: rgba(212, 175, 55, 0.1);
        color: var(--accent-gold);
        border-color: rgba(212, 175, 55, 0.2);
    }

        .btn-edit:hover {
            background: var(--accent-gold);
            color: #000;
        }

    .btn-delete {
        background: rgba(255, 71, 87, 0.1);
        color: var(--danger-red);
        border-color: rgba(255, 71, 87, 0.2);
    }

        .btn-delete:hover {
            background: var(--danger-red);
            color: #fff;
        }

    /* Footer Stats */
    .export-footer {
        margin-top: 2.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 1rem;
    }

    .btn-export {
        background: transparent;
        color: var(--danger-red);
        border: 1px solid var(--danger-red);
        padding: 10px 20px;
        border-radius: 12px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 600;
        transition: 0.3s;
        font-size: 0.85rem;
    }

        .btn-export:hover {
            background: var(--danger-red);
            color: white;
        }
</style>

<div class="books-page">
    <!-- Notifications Area -->
    <div class="alert-container">
        @if (TempData["SuccessMessage"] != null || TempData["Success"] != null)
        {
            <div class="custom-alert alert-success">
                <i class="fas fa-check-double fa-lg"></i>
                <span>@(TempData["SuccessMessage"] ?? TempData["Success"])</span>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="custom-alert alert-danger">
                <i class="fas fa-shield-virus fa-lg"></i>
                <span>@TempData["ErrorMessage"]</span>
            </div>
        }
    </div>

    <!-- Header -->
    <div class="page-header">
        <div class="page-title">
            <div style="display: flex; align-items: center; gap: 15px;">
                <i class="fas fa-crown fa-2x" style="color: var(--accent-gold)"></i>
                <h2>Library <span style="font-weight: 300; color: var(--text-main)">Curator</span></h2>
            </div>
            <p style="color: var(--text-dim); margin: 8px 0 0 50px; font-size: 0.9rem;">Overseeing literary assets and intellectual inventory.</p>
        </div>
        <a asp-action="AddBook" class="btn-add-book">
            <i class="fas fa-plus"></i> Add New Book
        </a>
    </div>

    <!-- Main Table -->
    <div class="table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>Publication</th>
                    <th>Classification</th>
                    <th>Creator</th>
                    <th style="text-align: center;">Command</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var book in Model)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 20px;">
                                <img src="@(string.IsNullOrEmpty(book.ImagePath) ? "/images/default-book.png" : book.ImagePath)"
                                     class="book-cover" alt="Cover"
                                     onerror="this.src='https://via.placeholder.com/60x85?text=No+Cover'" />
                                <div>
                                    <span class="book-title">@book.BookName</span>
                                    <span class="book-id">Asset Ref: #@book.BookId</span>
                                </div>
                            </div>
                        </td>
                        <td>
                            <span class="badge-category">@book.Category</span>
                        </td>
                        <td>
                            <div style="color: var(--text-main); font-weight: 500;">
                                <i class="fas fa-user-circle" style="color: var(--accent-gold); margin-right: 8px;"></i>@book.Author
                            </div>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a asp-action="EditBook" asp-route-id="@book.BookId" class="btn-action btn-edit" title="Edit Metadata">
                                    <i class="fas fa-pen-fancy"></i>
                                </a>

                                <form method="post" asp-controller="Admin" asp-action="DeleteBook"
                                      onsubmit="return confirm('Confirm permanent deletion of this asset?');">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@book.BookId" />
                                    <button type="submit" class="btn-action btn-delete" title="Remove Asset">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Footer Stats & Export -->
    <div class="export-footer">
        <div style="color: var(--text-dim); font-size: 0.85rem; display: flex; align-items: center; gap: 10px;">
            <i class="fas fa-info-circle" style="color: var(--accent-gold)"></i>
            Total Collection Volume: <strong style="color: var(--accent-gold)">@Model.Count Units</strong>
        </div>
        <a asp-action="ExportBooksPdf"
           asp-controller="Admin"
           asp-route-filter="all"
           class="btn-export">
            <i class="fas fa-file-pdf"></i> Generate Collection Report
        </a>
    </div>
</div>

@section Scripts {
    <script>
        // Auto-dismiss alerts with luxury fade out
        setTimeout(() => {
            const alerts = document.querySelectorAll('.custom-alert');
            alerts.forEach(alert => {
                alert.style.transition = "all 0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55)";
                alert.style.opacity = "0";
                alert.style.transform = "translateX(50px)";
                setTimeout(() => alert.remove(), 800);
            });
        }, 5000);
    </script>
}