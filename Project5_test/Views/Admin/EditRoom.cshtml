
@model Project5_test.Models.Room
@{
    ViewData["Title"] = "Edit Room";
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}

<!-- Google Fonts & Icons -->
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --royal-black: #050505;
        --deep-gray: #0f0f0f;
        --gold-linear: linear-gradient(135deg, #d4af37 0%, #f3cf7a 100%);
        --gold-glow: 0 0 20px rgba(212, 175, 55, 0.15);
        --border-glass: rgba(255, 255, 255, 0.08);
        --text-main: #f0f0f0;
        --text-dim: #a0a0a0;
        --accent-gold: #d4af37;
    }

    body {
        background-color: var(--royal-black);
        color: var(--text-main);
        font-family: 'Inter', sans-serif;
    }

    .edit-room-page {
        padding: 60px 20px;
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: flex-start;
    }

    .form-container {
        background-color: var(--deep-gray);
        border-radius: 24px;
        padding: 3rem;
        width: 100%;
        max-width: 650px;
        border: 1px solid var(--border-glass);
        box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-header {
        margin-bottom: 2.5rem;
        text-align: center;
    }

        .form-header i {
            background: var(--gold-linear);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 10px;
        }

        .form-header h2 {
            font-family: 'Playfair Display', serif;
            color: var(--accent-gold);
            font-size: 2.2rem;
            margin: 0;
            letter-spacing: 0.5px;
        }

    .form-group {
        margin-bottom: 1.8rem;
    }

        .form-group label {
            display: block;
            color: var(--text-dim);
            margin-bottom: 0.8rem;
            font-weight: 500;
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    .input-wrapper {
        position: relative;
    }

        .input-wrapper i {
            position: absolute;
            left: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--accent-gold);
            font-size: 1rem;
        }

    .form-control {
        width: 100%;
        padding: 1rem 1rem 1rem 3rem;
        border-radius: 12px;
        background-color: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--border-glass);
        color: var(--text-main);
        font-size: 1rem;
        transition: all 0.3s ease;
    }

        .form-control:focus {
            outline: none;
            border-color: var(--accent-gold);
            background-color: rgba(255, 255, 255, 0.06);
            box-shadow: var(--gold-glow);
        }

    .room-visual-card {
        background: rgba(212, 175, 55, 0.03);
        border: 1px dashed rgba(212, 175, 55, 0.2);
        border-radius: 15px;
        padding: 20px;
        text-align: center;
        margin-bottom: 2rem;
    }

    .icon-box {
        width: 70px;
        height: 70px;
        background: var(--gold-linear);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #000;
        font-size: 1.8rem;
        margin: 0 auto 15px;
        box-shadow: var(--gold-glow);
    }

    .btn-submit {
        background: var(--gold-linear);
        color: #000;
        padding: 1.1rem;
        border-radius: 12px;
        border: none;
        font-weight: 700;
        width: 100%;
        cursor: pointer;
        transition: 0.4s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 1rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

        .btn-submit:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(212, 175, 55, 0.3);
        }

    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--text-dim);
        text-decoration: none;
        margin-bottom: 2rem;
        font-size: 0.85rem;
        transition: 0.3s;
        font-weight: 500;
    }

        .btn-back:hover {
            color: var(--accent-gold);
        }

    /* Alerts */
    .custom-alert {
        padding: 15px 20px;
        border-radius: 12px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 12px;
        font-size: 0.9rem;
    }

    .alert-success {
        background: rgba(46, 213, 115, 0.1);
        color: #2ed573;
        border: 1px solid rgba(46, 213, 115, 0.2);
    }

    .alert-danger {
        background: rgba(255, 71, 87, 0.1);
        color: #ff4757;
        border: 1px solid rgba(255, 71, 87, 0.2);
    }
</style>

<div class="edit-room-page">
    <div class="form-container">
        @if (TempData["RoomSuccess"] != null)
        {
            <div class="custom-alert alert-success">
                <i class="fas fa-check-circle"></i>
                <span>@TempData["RoomSuccess"]</span>
            </div>
        }

        @if (TempData["RoomError"] != null)
        {
            <div class="custom-alert alert-danger">
                <i class="fas fa-exclamation-circle"></i>
                <span>@TempData["RoomError"]</span>
            </div>
        }

        <a asp-action="RoomsManagement" class="btn-back">
            <i class="fas fa-chevron-left"></i> Back to Archive
        </a>

        <div class="form-header">
            <i class="fas fa-door-open fa-3x"></i>
            <h2>Refine Room <span style="font-weight: 300; color: var(--text-main);">Details</span></h2>
            <p style="color: var(--text-dim); font-size: 0.85rem; margin-top: 8px;">Update technical specifications and availability</p>
        </div>

        <form asp-action="EditRoom" method="post">
            <input type="hidden" asp-for="RoomId" />
            @Html.AntiForgeryToken()

            <div class="room-visual-card">
                <div class="icon-box">
                    <i class="fas fa-pencil-ruler"></i>
                </div>
                <span style="font-size: 0.75rem; color: var(--accent-gold); text-transform: uppercase; font-weight: 700;">Configuration Asset #@Model.RoomId</span>
            </div>

            <div class="form-group">
                <label>Room Nomenclature</label>
                <div class="input-wrapper">
                    <i class="fas fa-signature"></i>
                    <input asp-for="RoomName" class="form-control" placeholder="e.g. Royal Suite A" required />
                </div>
                <span asp-validation-for="RoomName" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>

            <div class="form-group">
                <label>Occupancy Limit</label>
                <div class="input-wrapper">
                    <i class="fas fa-users"></i>
                    <input asp-for="Capacity" type="number" class="form-control" placeholder="Max persons..." required />
                </div>
                <span asp-validation-for="Capacity" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>

            <div class="form-group">
                <label>Operational Window (Time)</label>
                <div class="input-wrapper">
                    <i class="fas fa-clock"></i>
                    <input asp-for="RoomsTime" type="time" class="form-control" required />
                </div>
                <span asp-validation-for="RoomsTime" class="text-danger" style="font-size: 0.75rem;"></span>
            </div>

            <button type="submit" class="btn-submit">
                <i class="fas fa-save"></i> Save Specifications
            </button>
        </form>
    </div>
</div>