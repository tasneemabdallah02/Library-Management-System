@model Project5_test.Models.Book
@{
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --royal-black: #050505;
        --deep-gray: #0f0f0f;
        --gold-linear: linear-gradient(135deg, #d4af37 0%, #f3cf7a 100%);
        --gold-glow: 0 0 20px rgba(212, 175, 55, 0.2);
        --border-glass: rgba(255, 255, 255, 0.08);
        --text-main: #f0f0f0;
        --text-dim: #a0a0a0;
        --accent-gold: #d4af37;
    }

    .add-book-page {
        padding: 40px 2rem;
        background-color: var(--royal-black);
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        font-family: 'Inter', sans-serif;
    }

    .form-container {
        background-color: var(--deep-gray);
        border-radius: 24px;
        padding: 3rem;
        width: 100%;
        max-width: 700px;
        border: 1px solid var(--border-glass);
        box-shadow: 0 25px 50px rgba(0,0,0,0.6);
        animation: slideUp 0.6s ease-out;
    }

    @@keyframes slideUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .form-header {
        margin-bottom: 2.5rem;
        text-align: center;
    }

    .form-header h2 {
        font-family: 'Playfair Display', serif;
        color: var(--accent-gold);
        font-size: 2rem;
        margin: 10px 0;
    }

    /* Asset Preview Card */
    .book-preview-card {
        display: flex;
        align-items: center;
        gap: 25px;
        background: rgba(255, 255, 255, 0.03);
        padding: 1.5rem;
        border-radius: 18px;
        margin-bottom: 2.5rem;
        border: 1px solid var(--border-glass);
    }

    .book-preview-img {
        width: 65px;
        height: 90px;
        background: var(--gold-linear);
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #000;
        font-size: 1.8rem;
        box-shadow: var(--gold-glow);
        object-fit: cover;
    }

    /* Form Elements */
    .form-group {
        margin-bottom: 1.8rem;
    }

    .form-group label {
        display: block;
        color: var(--accent-gold);
        margin-bottom: 0.8rem;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .form-control {
        width: 100%;
        padding: 1rem 1.4rem;
        border-radius: 12px;
        background-color: rgba(255, 255, 255, 0.05);
        border: 1px solid var(--border-glass);
        color: var(--text-main);
        transition: all 0.3s ease;
        font-size: 1rem;
    }

    .form-control:focus {
        outline: none;
        border-color: var(--accent-gold);
        background-color: rgba(255, 255, 255, 0.08);
        box-shadow: 0 0 15px rgba(212, 175, 55, 0.1);
    }

    /* Custom File Upload */
    .file-upload-wrapper {
        position: relative;
        border: 2px dashed var(--border-glass);
        border-radius: 15px;
        padding: 2rem;
        text-align: center;
        transition: 0.3s;
        cursor: pointer;
        background: rgba(255, 255, 255, 0.01);
    }

    .file-upload-wrapper:hover {
        border-color: var(--accent-gold);
        background: rgba(212, 175, 55, 0.03);
    }

    .file-upload-wrapper i {
        font-size: 2.5rem;
        color: var(--accent-gold);
        margin-bottom: 15px;
        display: block;
    }

    .file-upload-wrapper input[type="file"] {
        position: absolute;
        width: 100%;
        height: 100%;
        top: 0;
        left: 0;
        opacity: 0;
        cursor: pointer;
    }

    /* Submit Button */
    .btn-submit {
        background: var(--gold-linear);
        color: #000;
        padding: 1.2rem;
        border-radius: 15px;
        border: none;
        font-weight: 800;
        width: 100%;
        cursor: pointer;
        transition: 0.4s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        font-size: 1rem;
        text-transform: uppercase;
        margin-top: 1rem;
        letter-spacing: 1px;
    }

    .btn-submit:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 30px rgba(212, 175, 55, 0.3);
    }

    .text-danger {
        font-size: 0.75rem;
        color: #ff4757;
        margin-top: 5px;
        display: block;
    }
</style>

<div class="add-book-page">
    <div class="form-container">

        <div class="form-header">
            <i class="fas fa-crown fa-3x" style="color: var(--accent-gold)"></i>
            <h2>Archive New Asset</h2>
            <p style="color: var(--text-dim);">Register a new literary masterpiece into the royal collection.</p>
        </div>

        <!-- Real-time Preview -->
        <div class="book-preview-card">
            <div id="preview-container">
                <div class="book-preview-img" id="icon-placeholder">
                    <i class="fas fa-book"></i>
                </div>
                <img id="image-preview" class="book-preview-img" style="display: none;" />
            </div>
            <div>
                <strong id="preview-title" style="display: block; color: var(--text-main); font-size: 1.2rem; font-family: 'Playfair Display', serif;">The Great Gatsby</strong>
                <span id="preview-author" style="font-size: 0.9rem; color: var(--accent-gold); font-weight: 500;">F. Scott Fitzgerald</span>
                <div id="preview-category" style="margin-top: 8px; font-size: 0.7rem; color: var(--text-dim); text-transform: uppercase; letter-spacing: 1px;">Classic</div>
            </div>
        </div>

        <form asp-action="AddBook" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="BookName">Publication Title</label>
                <input asp-for="BookName" id="title-input" class="form-control" placeholder="Enter book title..." required />
                <span asp-validation-for="BookName" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Author">Primary Creator</label>
                <input asp-for="Author" id="author-input" class="form-control" placeholder="Enter author's name..." required />
                <span asp-validation-for="Author" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category">Collection Classification</label>
                <select asp-for="Category" id="category-input" class="form-control" required>
                    <option value="" disabled selected>-- Select Classification --</option>
                    <option value="History">History</option>
                    <option value="Sciences">Sciences</option>
                    <option value="Math">Math</option>
                    <option value="Engineering">Engineering</option>
                    <option value="Classic">Classic</option>
                    <option value="Philosophical Fiction">Philosophical Fiction</option>
                </select>
                <span asp-validation-for="Category" class="text-danger"></span>
            </div>

            <div class="form-group">
                <label>Asset Visual (Cover)</label>
                <div class="file-upload-wrapper">
                    <i class="fas fa-upload"></i>
                    <p id="file-name-display" style="margin: 0; color: var(--text-dim); font-size: 0.85rem;">
                        Upload cover image (JPEG, PNG)
                    </p>
                    <input type="file" name="imageFile" id="file-input-asset" accept="image/*" required />
                </div>
            </div>

            <button type="submit" class="btn-submit">
                <i class="fas fa-plus"></i> Finalize Archiving
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        const titleIn = document.getElementById('title-input');
        const authorIn = document.getElementById('author-input');
        const catIn = document.getElementById('category-input');
        const fileIn = document.getElementById('file-input-asset');

        const titlePre = document.getElementById('preview-title');
        const authorPre = document.getElementById('preview-author');
        const catPre = document.getElementById('preview-category');
        const fileNameDisp = document.getElementById('file-name-display');
        
        const imgPre = document.getElementById('image-preview');
        const iconPlaceholder = document.getElementById('icon-placeholder');

        // Text Updates
        titleIn.addEventListener('input', (e) => titlePre.textContent = e.target.value || "Untitled Asset");
        authorIn.addEventListener('input', (e) => authorPre.textContent = e.target.value || "Unknown Creator");
        catIn.addEventListener('change', (e) => catPre.textContent = e.target.value);

        // Image Preview Logic
        fileIn.addEventListener('change', function(e) {
            if (this.files && this.files[0]) {
                const reader = new FileReader();
                fileNameDisp.textContent = "Asset Selected: " + this.files[0].name;
                fileNameDisp.style.color = "var(--accent-gold)";

                reader.onload = function(e) {
                    imgPre.src = e.target.result;
                    imgPre.style.display = 'block';
                    iconPlaceholder.style.display = 'none';
                }
                reader.readAsDataURL(this.files[0]);
            }
        });
    </script>
}
