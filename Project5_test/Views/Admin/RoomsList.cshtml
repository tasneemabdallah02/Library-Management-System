
@model List<Project5_test.Models.RoomReservation>
@{
    ViewData["Title"] = "Room List";
    Layout = "/Views/Shared/_LayoutDash.cshtml";
}

<!-- Google Fonts & Font Awesome -->
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    :root {
        --dark-bg: #0a0a0a;
        --card-bg: #141414;
        --gold-primary: #d4af37;
        --gold-secondary: #f3cf7a;
        --gold-glow: rgba(212, 175, 55, 0.3);
        --text-muted: #888;
        --text-light: #e0e0e0;
        --border-color: #2a2a2a;
        --danger: #ff4757;
        --warning: #ffa502;
    }

    body {
        background-color: var(--dark-bg);
        color: var(--text-light);
        font-family: 'Poppins', sans-serif;
        margin: 0;
    }

    .rooms-wrapper {
        padding: 30px;
    }

    /* الرأس (Header) */
    .section-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 40px;
        border-left: 4px solid var(--gold-primary);
        padding-left: 20px;
    }

        .section-header h2 {
            font-size: 2.2rem;
            margin: 0;
            color: var(--gold-primary);
            text-transform: uppercase;
            letter-spacing: 1px;
        }

    /* بطاقة الجدول الفاخرة */
    .luxury-card {
        background: var(--card-bg);
        border-radius: 20px;
        border: 1px solid var(--border-color);
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .table-container {
        width: 100%;
        overflow-x: auto;
    }

    .modern-table {
        width: 100%;
        border-collapse: collapse;
    }

        .modern-table th {
            background: #1a1a1a;
            padding: 1.5rem;
            color: var(--gold-primary);
            font-size: 0.85rem;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            text-align: left;
            border-bottom: 2px solid var(--border-color);
        }

        .modern-table td {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
            vertical-align: middle;
            transition: 0.3s;
        }

        .modern-table tr:hover td {
            background: rgba(212, 175, 55, 0.03);
        }

    /* تفاصيل الغرفة */
    .room-info-box {
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .room-icon {
        width: 45px;
        height: 45px;
        background: rgba(212, 175, 55, 0.1);
        border: 1px solid var(--gold-primary);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--gold-primary);
        font-size: 1.2rem;
    }

    /* الشارات (Badges) */
    .user-badge {
        background: rgba(212, 175, 55, 0.1);
        color: var(--gold-secondary);
        padding: 8px 14px;
        border-radius: 10px;
        font-size: 0.9rem;
        font-weight: 500;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    /* الأزرار */
    .action-group {
        display: flex;
        gap: 12px;
    }

    .btn-gold-outline {
        padding: 10px 18px;
        border-radius: 10px;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        transition: 0.3s;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        border: 1px solid transparent;
        cursor: pointer;
    }

    .btn-edit {
        background: rgba(255, 165, 2, 0.05);
        color: var(--warning);
        border-color: var(--warning);
    }

        .btn-edit:hover {
            background: var(--warning);
            color: #000;
        }

    .btn-delete {
        background: rgba(255, 71, 87, 0.05);
        color: var(--danger);
        border-color: var(--danger);
    }

        .btn-delete:hover {
            background: var(--danger);
            color: #fff;
        }

    .btn-add-main {
        background: linear-gradient(135deg, var(--gold-primary), var(--gold-secondary));
        color: #000 !important;
        padding: 14px 28px;
        border-radius: 14px;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 4px 15px var(--gold-glow);
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .btn-add-main:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px var(--gold-glow);
        }

    .export-section {
        margin-top: 30px;
        display: flex;
        justify-content: flex-end;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }

        .empty-state i {
            color: var(--border-color);
            margin-bottom: 20px;
        }
</style>

<div class="rooms-wrapper">

    <!-- رأس الصفحة -->
    <div class="section-header">
        <div>
            <h2>Room <span style="color: var(--gold-secondary)">List</span></h2>
            <p style="color: var(--text-muted); margin: 8px 0 0;">Manage and monitor all library study rooms</p>
        </div>
        <a asp-action="AddRoom" class="btn-add-main">
            <i class="fas fa-plus-circle"></i> Add New Room
        </a>
    </div>

    <!-- بطاقة الجدول -->
    <div class="luxury-card">
        <div class="table-container">
            <table class="modern-table">
                <thead>
                    <tr>
                        <th>Room Identification</th>
                        <th>Current Reservation</th>
                        <th>Time Interval</th>
                        <th>Date Added</th>
                        <th>Control</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var room in Model)
                        {
                            <tr>
                                <td>
                                    <div class="room-info-box">
                                        <div class="room-icon">
                                            <i class="fas fa-door-open"></i>
                                        </div>
                                        <div>
                                            <div style="font-weight: 600; color: #fff; font-size: 1.1rem;">@(room.Room?.RoomName ?? "Unknown Room")</div>
                                            <small style="color: var(--text-muted)">System ID: #@room.RoomId</small>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="user-badge">
                                        <i class="fas fa-id-badge"></i>
                                        @(room.User != null ? (room.User.FirstName + " " + room.User.LastName) : "No Active User")
                                    </span>
                                </td>
                                <td>
                                    <div style="color: var(--gold-secondary); font-weight: 500;">
                                        <i class="far fa-clock" style="margin-right: 5px;"></i> @room.StartTime - @room.EndTime
                                    </div>
                                </td>
                                <td>
                                    <div style="color: var(--text-muted); font-size: 0.9rem;">
                                        <i class="far fa-calendar-alt" style="margin-right: 5px;"></i>
                                        @(room.ReservationDate?.ToString("MMM dd, yyyy") ?? "N/A")
                                    </div>
                                </td>
                                <td>
                                    <div class="action-group">
                                        <a asp-action="EditRoom" asp-route-id="@room.RoomId" class="btn-gold-outline btn-edit">
                                            <i class="fas fa-pen"></i> Edit
                                        </a>

                                        <form asp-action="DeleteRoom" method="post" onsubmit="return confirm('Are you certain you want to remove this room?')">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@room.RoomId" />
                                            <button type="submit" class="btn-gold-outline btn-delete">
                                                <i class="fas fa-trash"></i> Delete
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5">
                                <div class="empty-state">
                                    <i class="fas fa-folder-open fa-4x"></i>
                                    <h3 style="color: var(--text-light)">No Rooms Available</h3>
                                    <p style="color: var(--text-muted)">The room database is currently empty. Click 'Add New Room' to begin.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- التصدير -->
    <div class="export-section">
        <a asp-action="ExportRoomsPdf" asp-controller="Admin" class="btn-gold-outline" style="border-color: var(--gold-primary); color: var(--gold-primary); background: rgba(212, 175, 55, 0.05);">
            <i class="fas fa-download"></i> Generate PDF Report
        </a>
    </div>

</div>