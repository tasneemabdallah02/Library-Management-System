                                style: { colors: '#a0a3bd' },
                                formatter: (value) => `$${value.toLocaleString()}`
                            }
                        },
                        tooltip: { theme: 'dark' }
                    };

                    static userActivityChartOptions = {
                        series: [{
                            name: 'New Users',
                            data: [44, 55, 57, 56, 61, 58, 63]
                        }, {
