<!DOCTYPE html>
<html lang="en" dir="ltr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Elite Management System</title>

    <!-- External Assets -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        :root {
            --royal-gold: #D4AF37;
            --gold-light: #F1D47A;
            --gold-dark: #B8860B;
            --deep-black: #050505;
            --card-bg: rgba(18, 18, 18, 0.95);
            --sidebar-width: 280px;
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--deep-black);
            color: #e0e0e0;
            overflow-x: hidden;
            margin: 0;
        }

        /* Sidebar Styles */
        .sidebar {
            width: var(--sidebar-width);
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background: var(--card-bg);
            border-right: 1px solid rgba(212, 175, 55, 0.15);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            backdrop-filter: blur(25px);
        }

        .royal-logo {
            font-family: 'Cinzel', serif;
            font-size: 1.8rem;
            background: linear-gradient(to right, var(--gold-light), var(--royal-gold), var(--gold-dark));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: bold;
            letter-spacing: 3px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            padding: 12px 18px;
            margin-bottom: 5px;
            border-radius: 12px;
            color: #999;
            text-decoration: none;
            transition: var(--transition);
            font-size: 0.9rem;
            border: 1px solid transparent;
        }

            .nav-item i {
                width: 25px;
                color: var(--royal-gold);
                opacity: 0.7;
                margin-right: 12px;
            }

            .nav-item:hover, .nav-item.active {
                color: #fff;
                background: rgba(212, 175, 55, 0.1);
                border-left: 3px solid var(--royal-gold);
                border-color: rgba(212, 175, 55, 0.1);
            }

        /* Layout */
        .main-container {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }

        .top-bar {
            height: 75px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 35px;
            background: rgba(5, 5, 5, 0.8);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: sticky;
            top: 0;
            z-index: 900;
        }

        /* Notifications */
        .notification-wrapper {
            position: relative;
        }

        .notif-badge {
            position: absolute;
            top: -5px;
            right: -5px;
            background: #ef4444;
            color: white;
            font-size: 10px;
            font-weight: bold;
            width: 18px;
            height: 18px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid var(--deep-black);
        }

        .notif-dropdown {
            position: absolute;
            top: 120%;
            right: 0;
            width: 350px;
            background: #1a1a1a;
            border: 1px solid rgba(212, 175, 55, 0.2);
            border-radius: 15px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.5);
            display: none;
            flex-direction: column;
            z-index: 1001;
            transform-origin: top right;
        }

        .notif-item {
            padding: 15px 20px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
            display: flex;
            gap: 15px;
            cursor: pointer;
            text-decoration: none;
        }

            .notif-item b {
                color: var(--gold-light);
            }

        .notif-content p {
            color: #ccc;
            font-size: 0.85rem;
            margin: 0;
        }
    </style>
</head>
<body>

    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="p-8 border-b border-white/5">
            <div class="royal-logo">ELITE</div>
            <div class="text-[10px] tracking-[4px] text-gray-500 mt-1 uppercase">Management</div>
        </div>

        <nav class="flex-1 px-4 py-6 overflow-y-auto">
            <div class="text-[10px] text-gray-600 uppercase tracking-widest mb-4 ml-4">General</div>
            <a asp-controller="Home" asp-action="Index" class="nav-item active">
                <i class="fas fa-th-large"></i><span>Dashboard</span>
            </a>

            <div class="text-[10px] text-gray-600 uppercase tracking-widest mt-8 mb-4 ml-4">Administration</div>

            <!-- تم إضافة الأكشن والكنترولر هنا -->
            <a asp-controller="Admin" asp-action="UsersList" method="get" class="nav-item">
                <i class="fas fa-users"></i><span>Users List</span>
            </a>

            <a asp-controller="Admin" asp-action="ManageFeedback" class="nav-item">
                <i class="fas fa-user-cog"></i><span>Feedback</span>
            </a>

            <div class="text-[10px] text-gray-600 uppercase tracking-widest mt-8 mb-4 ml-4">Resources</div>
            <a asp-controller="Admin" asp-action="BooksList" class="nav-item">
                <i class="fas fa-book"></i><span>Library Books</span>
            </a>
            <a asp-controller="Admin" asp-action="ManageBorrows" class="nav-item">
                <i class="fas fa-book"></i><span>Borrow Request</span>
            </a>
            <a asp-controller="Admin" asp-action="RoomsList" class="nav-item">
                <i class="fas fa-door-open"></i><span>Rooms List</span>
            </a>
            <a asp-controller="Admin" asp-action="ManageReservations" class="nav-item">
                <i class="fas fa-door-open"></i><span>Rooms Reservation</span>
            </a>
            <div class="text-[10px] text-gray-600 uppercase tracking-widest mt-8 mb-4 ml-4 font-semibold">
                System Settings
            </div>

            <a asp-controller="Admin" asp-action="Logout" class="nav-item group hover:!bg-red-500/10 hover:!border-red-500/50 transition-all duration-300">
                <i class="fas fa-power-off text-red-500/70 group-hover:text-red-500 transition-colors"></i>
                <span class="group-hover:text-red-500">Log Out</span>
            </a>
        </nav>
    </aside>

    <div class="main-container">
        <!-- Top Bar -->
        <header class="top-bar">
            <div class="flex items-center gap-4">
                <h1 class="text-sm font-semibold tracking-widest text-gray-400">@ViewData["Title"]</h1>
            </div>

            <div class="flex items-center gap-6">
                <!-- Notifications Dropdown -->
                <div class="notification-wrapper">
                    <button id="notif-btn" class="relative w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-royal-gold transition-all">
                        <i class="far fa-bell text-xl"></i>
                        <span class="notif-badge">3</span>
                    </button>

                    <div id="notif-menu" class="notif-dropdown">
                        <div class="p-4 border-b border-white/10 flex justify-between items-center">
                            <span class="text-xs font-bold uppercase tracking-wider">Requests Notifications</span>
                            <span class="text-[10px] text-royal-gold cursor-pointer">Clear All</span>
                        </div>
                        <div class="max-height-[300px] overflow-y-auto" id="notif-container">
                            <!-- القائمة التي يظهر فيها الريكويست -->
                            <a asp-controller="Admin" asp-action="UsersList" class="notif-item">
                                <div class="w-8 h-8 rounded bg-gold-dark/20 flex items-center justify-center text-royal-gold">
                                    <i class="fas fa-user-plus text-xs"></i>
                                </div>
                                <div class="notif-content">
                                    <p>New <b>User Request</b> from Khaled.</p>
                                    <span class="text-[10px] text-gray-600">5 mins ago</span>
                                </div>
                            </a>
                        </div>
                        <a asp-controller="Admin" asp-action="UsersList" class="block p-3 text-center text-[11px] text-royal-gold hover:bg-white/5">
                            View All Requests
                        </a>
                    </div>
                </div>

                <!-- Admin Identity -->
                <div class="flex items-center gap-3">
                    <div class="text-right hidden sm:block">
                        <p class="text-[11px] font-bold text-white leading-none">System Admin</p>
                        <p class="text-[9px] text-royal-gold">Verified Elite</p>
                    </div>
                    <div class="w-9 h-9 rounded-xl bg-gradient-to-tr from-gold-dark to-gold-light p-[1px]">
                        <div class="w-full h-full rounded-xl bg-black flex items-center justify-center">
                            <i class="fas fa-user-shield text-royal-gold text-xs"></i>
                        </div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Body -->
        <main class="p-8">
            @RenderBody()
        </main>
    </div>

    <script>
        // Notification Toggle Logic
        const btn = document.getElementById('notif-btn');
        const menu = document.getElementById('notif-menu');

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            menu.style.display = menu.style.display === 'flex' ? 'none' : 'flex';
        });

        document.addEventListener('click', () => {
            menu.style.display = 'none';
        });

        // تم إضافة منطق لفتح القائمة عند استلام ريكويست (Simulation)
        function notifyNewRequest(userName) {
            const container = document.getElementById('notif-container');
            const badge = document.querySelector('.notif-badge');

            badge.innerText = parseInt(badge.innerText) + 1;

            const html = `
                <a href="/Admin/UsersList" class="notif-item">
                    <div class="w-8 h-8 rounded bg-gold-dark/20 flex items-center justify-center text-royal-gold">
                        <i class="fas fa-bell text-xs"></i>
                    </div>
                    <div class="notif-content">
                        <p>New <b>Request</b> from ${userName}.</p>
                        <span class="text-[10px] text-gray-600">Just now</span>
                    </div>
                </a>
            `;
            container.insertAdjacentHTML('afterbegin', html);
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>