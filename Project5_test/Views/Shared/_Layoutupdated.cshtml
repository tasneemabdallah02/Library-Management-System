<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] - Elite Library</title>

    <!-- Global Luxury Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Marcellus&family=Montserrat:wght@200;300;400;500&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        :root {
            --bg-base: #050507;
            --accent-gold: #c5a059;
            --accent-gold-bright: #e5c17e;
            --glass-card: rgba(10, 10, 12, 0.85);
            --glass-stroke: rgba(255, 255, 255, 0.04);
            --text-high: #ffffff;
            --text-mid: #94949e;
            --transition-smooth: all 0.7s cubic-bezier(0.19, 1, 0.22, 1);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            transition: var(--transition-smooth);
        }

        body {
            background-color: var(--bg-base);
            color: var(--text-high);
            font-family: 'Montserrat', sans-serif;
            overflow-x: hidden;
            line-height: 1.6;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* --- Ambient Background Effects --- */
        .ambient-glow {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 10% 10%, rgba(197, 160, 89, 0.07) 0%, transparent 40%), radial-gradient(circle at 90% 90%, rgba(197, 160, 89, 0.04) 0%, transparent 40%);
            pointer-events: none;
            z-index: -2;
        }

        .noise-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: url('https://grainy-gradients.vercel.app/noise.svg');
            opacity: 0.04;
            pointer-events: none;
            z-index: -1;
        }

        /* --- NAVIGATION BAR (GLOBAL ELITE) --- */
        .navbar {
            width: 100%;
            padding: 25px 60px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: fixed;
            top: 0;
            z-index: 1000;
            background: linear-gradient(to bottom, var(--bg-base), transparent);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--glass-stroke);
        }

        .logo {
            font-family: 'Cinzel', serif;
            font-size: 1.6rem;
            letter-spacing: 6px;
            color: var(--accent-gold);
            text-decoration: none;
            font-weight: 700;
        }

        .nav-links {
            display: flex;
            align-items: center;
            gap: 35px;
            list-style: none;
        }

            .nav-links a {
                text-decoration: none;
                color: var(--text-mid);
                font-family: 'Cinzel', serif;
                font-size: 0.75rem;
                letter-spacing: 2px;
                text-transform: uppercase;
            }

                .nav-links a:hover {
                    color: var(--accent-gold);
                    letter-spacing: 3px;
                }


        /* --- الأنماط الجديدة للبحث --- */
        .search-container {
            position: relative;
            display: flex;
            align-items: center;
            margin-right: 15px;
        }

        .search-wrapper {
            display: flex;
            align-items: center;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid var(--glass-stroke);
            border-radius: 40px;
            padding: 4px;
            width: 42px; /* الحالة الابتدائية */
            height: 42px;
            overflow: hidden;
            transition: var(--transition-smooth);
            backdrop-filter: blur(5px);
        }

            .search-wrapper.active {
                width: 280px;
                background: rgba(255, 255, 255, 0.07);
                border-color: var(--accent-gold);
                box-shadow: 0 0 20px rgba(197, 160, 89, 0.1);
            }

        .search-input {
            background: transparent;
            border: none;
            outline: none;
            color: white;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.85rem;
            width: 0;
            padding: 0;
            transition: var(--transition-smooth);
            opacity: 0;
        }

        .search-wrapper.active .search-input {
            width: 200px;
            padding: 0 15px;
            opacity: 1;
        }

        .search-btn {
            background: transparent;
            border: none;
            color: var(--accent-gold);
            cursor: pointer;
            width: 34px;
            height: 34px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            flex-shrink: 0;
        }

            .search-btn:hover {
                background: rgba(197, 160, 89, 0.1);
            }
        /* Auth Items & Icons */
        .auth-item {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-left: 20px;
        }

        .profile-link {
            color: var(--accent-gold);
            display: flex;
            align-items: center;
            opacity: 0.8;
        }

            .profile-link:hover {
                opacity: 1;
                transform: scale(1.1);
            }

        .login-btn {
            border: 1px solid var(--accent-gold);
            padding: 10px 25px;
            color: var(--accent-gold) !important;
            font-weight: 400;
        }

            .login-btn:hover {
                background: var(--accent-gold);
                color: #000 !important;
            }

        /* --- FOOTER (BOUTIQUE STYLE) --- */
        .main-footer {
            background: rgba(0, 0, 0, 0.6);
            border-top: 1px solid var(--glass-stroke);
            padding: 80px 60px 40px;
            font-family: 'Montserrat', sans-serif;
        }

        .footer-top {
            display: grid;
            grid-template-columns: 1fr 2fr 1fr;
            gap: 50px;
            max-width: 1200px;
            margin: 0 auto 60px;
            align-items: start;
        }

        .footer-col ul {
            list-style: none;
        }

            .footer-col ul li {
                margin-bottom: 15px;
            }

                .footer-col ul li a {
                    text-decoration: none;
                    color: var(--text-mid);
                    font-family: 'Cinzel', serif;
                    font-size: 0.7rem;
                    letter-spacing: 2px;
                    text-transform: uppercase;
                }

                    .footer-col ul li a:hover {
                        color: var(--accent-gold);
                    }

        .footer-center {
            text-align: center;
        }

        .footer-logo {
            font-family: 'Cinzel', serif;
            font-size: 1.8rem;
            letter-spacing: 8px;
            color: var(--accent-gold);
            margin-bottom: 25px;
        }

        .footer-desc {
            color: var(--text-mid);
            font-size: 0.8rem;
            font-weight: 200;
            max-width: 400px;
            margin: 0 auto;
            line-height: 2;
        }

        .footer-bottom {
            max-width: 1200px;
            margin: 0 auto;
            padding-top: 40px;
            border-top: 1px solid rgba(255,255,255,0.05);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .copyright {
            font-size: 0.65rem;
            color: rgba(255,255,255,0.2);
            letter-spacing: 1px;
            text-transform: uppercase;
        }

        .social-icons {
            display: flex;
            gap: 25px;
        }

            .social-icons a {
                color: var(--text-mid);
                font-size: 0.9rem;
            }

                .social-icons a:hover {
                    color: var(--accent-gold);
                    transform: translateY(-3px);
                }

        /* Responsive */
        @@media (max-width: 900px) {
            .footer-top {
                grid-template-columns: 1fr;
                text-align: center;
            }

            .navbar {
                padding: 20px 30px;
            }

            .nav-links {
                display: none;
            }

            #container {
                padding: 50px 30px;
            }
        }
    </style>
</head>
<body>

    <div class="ambient-glow"></div>
    <div class="noise-overlay"></div>
    <div class="light-ray"></div>

    <!-- NAVBAR -->
    <header class="navbar">
        <a asp-controller="Home" asp-action="Index" class="logo">Elite</a>
        <nav>
            <ul class="nav-links">
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Books" asp-action="BooksList">Categories</a></li>
                <li><a asp-controller="Home" asp-action="Contact">Contact</a></li>
                <li><a asp-controller="Home" asp-action="About">About</a></li>

                <li class="search-container">
                    <form asp-controller="Books" asp-action="Search" method="get" id="searchForm">
                        <div class="search-wrapper" id="searchWrapper">
                            <input type="text" name="query" class="search-input" placeholder="Search by title, author..." id="searchInput">
                            <button type="button" class="search-btn" id="searchTrigger">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>
                </li>

                <li class="auth-item">
                    <!-- Logic for ASP.NET Core Sessions -->
                    @if (Context.Session.GetInt32("UserId") != null)
                    {
                        <a asp-controller="Profile" asp-action="Index" class="profile-link" title="Profile">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0" />
                                <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1" />
                            </svg>
                        </a>
                        <a asp-controller="Account" asp-action="Logout" class="login-btn">Logout</a>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="login-btn">Login</a>
                    }
                </li>
            </ul>
        </nav>
    </header>

    <main class="page-content">
        @RenderBody()
    </main>
<!-- FOOTER -->
<footer class="main-footer">
    <div class="footer-top">
        <div class="footer-col">
            <ul>
                <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                <li><a asp-controller="Home" asp-action="About">About</a></li>
                <li><a asp-controller="Home" asp-action="Contact">Contact Us</a></li>
            </ul>
        </div>

        <div class="footer-col footer-center">
            <div class="footer-logo">Elite</div>
            <p class="footer-desc">
                Curating the world's most distinguished literary collections. Experience the pinnacle of archival excellence.
            </p>
        </div>

        <div class="footer-col" style="text-align: right;">
            <ul>
                <li><a asp-controller="Services" asp-action="Index">Services</a></li>
                <li><a asp-controller="Authors" asp-action="Index">Authors</a></li>
            </ul>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="copyright">
            &copy; 2026 All Rights Reserved - Elite Boutique
        </div>
        <div class="social-icons">
            <a href="#"><i class="fab fa-instagram"></i></a>
            <a href="#"><i class="fab fa-facebook-f"></i></a>
            <a href="#"><i class="fas fa-phone"></i></a>
            <a href="#"><i class="fab fa-linkedin-in"></i></a>
            <a href="#"><i class="fab fa-x-twitter"></i></a>
        </div>
    </div>
</footer>

<script>
            // Search Logic
            const searchTrigger = document.getElementById('searchTrigger');
            const searchWrapper = document.getElementById('searchWrapper');
            const searchInput = document.getElementById('searchInput');
            const searchForm = document.getElementById('searchForm');

            searchTrigger.addEventListener('click', (e) => {
                e.stopPropagation();
                if (!searchWrapper.classList.contains('active')) {
                    searchWrapper.classList.add('active');
                    searchInput.focus();
                } else {
                    if (searchInput.value.trim() !== "") {
                        searchForm.submit();
                    } else {
                        searchWrapper.classList.remove('active');
                    }
                }
            });

            // Close search when clicking outside
            document.addEventListener('click', (e) => {
                if (!searchWrapper.contains(e.target)) {
                    searchWrapper.classList.remove('active');
                }
            });

            // Prevent closing when clicking inside input
            searchInput.addEventListener('click', (e) => e.stopPropagation());

    // Subtle 3D movement for the main container
    const container = document.getElementById('container');
    if(container) {
        document.addEventListener('mousemove', (e) => {
            const xAxis = (window.innerWidth / 2 - e.pageX) / 100;
            const yAxis = (window.innerHeight / 2 - e.pageY) / 100;
            container.style.transform = `rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
        });
    }
</script>
</body>
</html>