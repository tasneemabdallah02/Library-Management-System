@model Project5_test.Models.User
@{
    Layout = null;
}

<style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: 'Segoe UI', sans-serif;
    }

    body {
        height: 100vh;
        background: url('/Images/log_re.jpg') no-repeat center center/cover;
        display: flex;
        justify-content: center;
        align-items: center;
        padding-right: 120px;
    }

    .login-card {
        width: 480px;
        padding: 50px;
        border-radius: 20px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(12px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        color: white;
    }

        .login-card h2 {
            text-align: center;
            margin-bottom: 25px;
            font-weight: 400;
        }

    .form-group {
        margin-bottom: 18px;
    }

    .form-control {
        width: 100%;
        padding: 15px;
        border-radius: 10px;
        background: rgba(255,255,255,0.3);
        color: white;
        border: none;
        outline: none;
    }

        .form-control::placeholder {
            color: #eee;
        }

    .btn-login {
        width: 100%;
        padding: 12px;
        border-radius: 12px;
        background: rgba(255,255,255,0.4);
        color: white;
        border: none;
        cursor: pointer;
        transition: .3s;
        font-size: 16px;
        margin-top: 10px;
    }

        .btn-login:hover {
            background: white;
            color: #333;
        }

    .error-msg {
        color: #ff4d4d;
        text-align: center;
        margin-bottom: 15px;
        font-size: 14px;
        background: rgba(0,0,0,0.2);
        padding: 5px;
        border-radius: 5px;
    }

    .back-to-login {
        text-align: center;
        margin-top: 15px;
        font-size: 14px;
    }

        .back-to-login a {
            color: #fff;
            text-decoration: underline;
        }
</style>

<form class="login-card" asp-action="ForgotPassword" asp-controller="Account" method="post">
    <h2>Reset Password</h2>

    @if (ViewBag.msg != null)
    {
        <div class="error-msg">@ViewBag.msg</div>
    }

    <div class="form-group">
        <input name="email" type="email" class="form-control" placeholder="Enter your University Email" required />
    </div>

    <div class="form-group">
        <input name="newPassword" type="password" class="form-control" placeholder="New Password" required />
    </div>

    <div class="form-group">
        <input name="confirmPassword" type="password" class="form-control" placeholder="Confirm New Password" required />
    </div>

    <button type="submit" class="btn-login">Save Changes</button>

    <div class="back-to-login">
        <a asp-action="Login">Back to Login</a>
    </div>
</form>